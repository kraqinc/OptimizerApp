<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <FrameLayout
        android:id="@+id/pageRam"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/ramInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_gravity="center"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/pageTweaks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTweaks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/pageSystem"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <TextView
            android:id="@+id/systemInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_gravity="center"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#111111">

        <TextView
            android:id="@+id/tabRam"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="RAM"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tabTweaks"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="TWEAKS"
            android:textColor="#888888"/>

        <TextView
            android:id="@+id/tabSystem"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SYSTEM"
            android:textColor="#888888"/>
    </LinearLayout>

</LinearLayout>
